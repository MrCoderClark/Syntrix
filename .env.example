# ---- Frontend ----
BACKEND_URL=http://127.0.0.1:8001

# ---- Database (via Supavisor pooler) ----
# Username includes the tenant ID: postgres.<POOLER_TENANT_ID>
PG_HOST=127.0.0.1
PG_PORT=6543
PG_DB=postgres
PG_USER=postgres.your-tenant-id
PG_PASSWORD=

# ---- Auth (Section 04) ----
JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# URLs
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8001
FRONTEND_URL=http://127.0.0.1:3000
